{
    "manifest_version": 2,
    "name": "Garmin Trail-Passion Bridge",
    "version": "1.0.0",
    "description": "Bridge Garmin Connect with Trail-Passion",
    "content_scripts": [
        {
            "matches": [
                "https://connect.garmin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "permissions": []
}